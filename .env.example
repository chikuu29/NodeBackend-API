# Node Environment
NODE_ENV=development

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:5173/api/v1/oauth/google/callback

# Database Configuration
MONGO_URI=mongodb://localhost:27017/workspace_db

# Server Configuration
PORT=7000
HOST=localhost

# OAuth2 Server Configuration
OAUTH_CLIENT_ID=your_oauth_client_id_here
OAUTH_CLIENT_SECRET=your_oauth_client_secret_here
OAUTH_TOKEN_URI=http://localhost:8000/oauth2/token
OAUTH_OPENID_CONFIG_URL=http://localhost:8000/.well-known/openid-configuration
